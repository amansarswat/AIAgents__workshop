# =====================================================================
# Agentic AI Masterclass — environment template
# =====================================================================
# 1. Copy this file to `.env`  (cp .env.example .env)
# 3. Never commit `.env` — it is git-ignored.
#
# NOTE: in Azure, the "model" you call is the DEPLOYMENT NAME you created in
# the Azure portal, which may differ from the underlying model name.
# =====================================================================

AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=<Your key>
AZURE_OPENAI_API_VERSION=2024-10-21

# The deployment all demos use. gpt-4o-mini is the most reliable for tool-calling.
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini

CREWAI_TRACING_ENABLED=false
